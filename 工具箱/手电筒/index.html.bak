<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>手电筒</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:system-ui}
body{background:#000;color:#fff;min-height:100vh;display:grid;place-items:center}
.container{text-align:center}

.flash-btn{
width:200px;height:200px;
border-radius:50%;
background:radial-gradient(circle,#ff0 0,#f80 100%);
border:none;
font-size:28px;font-weight:bold;
color:#000;
box-shadow:0 0 50px rgba(255,180,0,0.7),0 0 100px rgba(255,120,0,0.4);
cursor:pointer;
transition:all 0.2s ease;
-webkit-tap-highlight-color:transparent;
margin-bottom:15px;
}
.flash-btn:active{transform:scale(0.94)}
.flash-btn.off{
background:#222;
color:#666;
box-shadow:none
}

.flash-btn-strobe{
width:200px;height:100px;
border-radius:20px;
background:radial-gradient(circle,#fff 0,#f00 100%);
border:none;
font-size:24px;font-weight:bold;
color:#fff;
box-shadow:0 0 50px rgba(255,0,0,0.7),0 0 100px rgba(255,0,0,0.4);
cursor:pointer;
transition:all 0.2s ease;
-webkit-tap-highlight-color:transparent;
}
.flash-btn-strobe.off{
background:#222;color:#666;box-shadow:none
}

.status{margin-top:20px;font-size:16px;color:#aaa}
.tip{margin-top:10px;font-size:14px;color:#666}
</style>
</head>

<body>
<div class="container">
<button class="flash-btn" id="torchBtn">普通手电</button>
<button class="flash-btn-strobe" id="strobeBtn">超强爆闪</button>
<div class="status" id="status">等待操作...</div>
<div class="tip">需允许相机/闪光灯权限</div>
</div>

<script>
const btn = document.getElementById('torchBtn');
const btnStrobe = document.getElementById('strobeBtn');
const status = document.getElementById('status');

let track = null;
let isOn = false;
let strobeInterval = null;

// 初始化闪光灯流
async function initTorch() {
  if (track) return track;
  const stream = await navigator.mediaDevices.getUserMedia({
    video: { facingMode: 'environment' }
  });
  track = stream.getVideoTracks()[0];
  return track;
}

// 普通常亮
btn.addEventListener('click', async () => {
  try {
    stopStrobe();
    const t = await initTorch();
    
    if (!isOn) {
      await t.applyConstraints({ advanced: [{ torch: true }] });
      isOn = true;
      btn.textContent = '关闭手电';
      btn.classList.remove('off');
      status.textContent = '常亮模式';
    } else {
      await t.applyConstraints({ advanced: [{ torch: false }] });
      isOn = false;
      btn.textContent = '普通手电';
      btn.classList.add('off');
      status.textContent = '已关闭';
    }
  } catch(e) {
    status.textContent = '权限或设备不支持';
  }
});

// 超强爆闪（极速频闪，视觉更亮）
btnStrobe.addEventListener('click', async () => {
  try {
    if (strobeInterval) {
      stopStrobe();
      status.textContent = '爆闪关闭';
      btnStrobe.textContent = '超强爆闪';
      btnStrobe.classList.add('off');
      return;
    }

    stopTorch();
    const t = await initTorch();
    
    btnStrobe.textContent = '关闭爆闪';
    btnStrobe.classList.remove('off');
    status.textContent = '超强爆闪模式';

    strobeInterval = setInterval(async () => {
      try {
        await t.applyConstraints({ advanced: [{ torch: true }] });
        setTimeout(() => {
          t.applyConstraints({ advanced: [{ torch: false }] });
        }, 20);
      } catch {}
    }, 40);
  } catch(e) {
    status.textContent = '权限或设备不支持';
  }
});

function stopStrobe() {
  clearInterval(strobeInterval);
  strobeInterval = null;
}

function stopTorch() {
  if (track && isOn) {
    track.applyConstraints({ advanced: [{ torch: false }] });
    isOn = false;
    btn.textContent = '普通手电';
    btn.classList.add('off');
  }
}
</script>
</body>
</html>
